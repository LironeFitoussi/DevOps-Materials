{
  "info": {
    "name": "Config Store API",
    "description": "Unit tests for the Config Store KV API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "testKey",
      "value": "postman-test-key",
      "type": "string"
    },
    {
      "key": "testValue",
      "value": "postman-test-value",
      "type": "string"
    },
    {
      "key": "updatedValue",
      "value": "postman-updated-value",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "GET /api/kv - List all KV pairs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has data array', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.be.an('array');",
              "});",
              "",
              "pm.test('Content-Type is application/json', function () {",
              "  pm.response.to.have.header('Content-Type');",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Response time is under 2000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/kv",
          "host": ["{{baseUrl}}"],
          "path": ["api", "kv"]
        }
      }
    },
    {
      "name": "POST /api/kv - Create a KV pair",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contains created KV pair', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.have.property('key', pm.collectionVariables.get('testKey'));",
              "  pm.expect(body.data).to.have.property('value', pm.collectionVariables.get('testValue'));",
              "});",
              "",
              "pm.test('Content-Type is application/json', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Response time is under 2000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"key\": \"{{testKey}}\",\n  \"value\": \"{{testValue}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/kv",
          "host": ["{{baseUrl}}"],
          "path": ["api", "kv"]
        }
      }
    },
