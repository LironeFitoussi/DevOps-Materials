# AWS ALB Ingress — requires AWS Load Balancer Controller installed in cluster
# HTTP traffic is redirected to HTTPS automatically via ssl-redirect annotation
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: orders-app-ingress
  namespace: orders-app
  annotations:
    kubernetes.io/ingress.class: alb
    alb.ingress.kubernetes.io/scheme: internet-facing
    alb.ingress.kubernetes.io/target-type: ip
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTP":80},{"HTTPS":443}]'
    alb.ingress.kubernetes.io/ssl-redirect: '443'
    # TODO: replace YOUR_DOMAIN with your actual domain (e.g. example.com)
    external-dns.alpha.kubernetes.io/hostname: orders.iitc-course.com
    cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  ingressClassName: alb
  rules:
    - host: orders.iitc-course.com   # TODO: replace YOUR_DOMAIN
      http:
        paths:
          # API requests go to backend — order matters: more specific path first
          - path: /api
            pathType: Prefix
            backend:
              service:
                name: backend
                port:
                  number: 3000
          # All other traffic goes to frontend (React SPA)
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend
                port:
                  number: 80
